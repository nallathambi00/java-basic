package jp.ac.hal;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;

public class 演習6 {
    public static void main(String[] args) throws IOException {

        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));

        int res = 0;
         int PRICE = 130;

        while (true) {
            System.out.print("硬貨を投入してください:");
            String str = br.readLine();
            int coin = Integer.parseInt(str);

            // 0 → end program
            if (coin == 0) {
                System.out.println("終了します。");
                System.out.println("返却金額"+res);
                
                break;
            }

            // valid coin?
            if (coin == 10 || coin == 50 || coin == 100 || coin == 500) {
                res += coin;

                // check if drink can be purchased
                int count = res / PRICE;
                if (count > 0) {
                    System.out.println("ドリンク" + count + "本!");
                    res -= PRICE * count;
                   
                   
                }

                System.out.println("合計金額:¥" + res);

            } else {
                System.out.println("有効な硬貨(10、50、100、500)を投入してください。");
            }
        }
    }
}
